generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  telegramId   BigInt?   @unique
  username     String?   @unique
  firstName    String?
  lastName     String?
  photoUrl     String?
  email        String?   @unique
  passwordHash String?
  telegramBotToken String?
  telegramChatId   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projects     Project[]
  transfersOut TransferRequest[] @relation("TransferFrom")
  transfersIn  TransferRequest[] @relation("TransferTo")
}

model Project {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  name        String
  html        String    @db.Text
  css         String    @db.Text
  js          String    @db.Text @default("")
  edits       Json      @default("[]")
  tokens      Json      @default("{}")
  published   Boolean   @default(false)
  publishedAt DateTime?
  publishUrl  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads       Lead[]
  transfers   TransferRequest[]

  @@index([userId])
}

model Lead {
  id        Int      @id @default(autoincrement())
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  data      Json
  source    String?
  createdAt DateTime @default(now())

  @@index([projectId])
}

model TransferRequest {
  id        Int      @id @default(autoincrement())
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromId    Int
  from      User     @relation("TransferFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toId      Int
  to        User     @relation("TransferTo", fields: [toId], references: [id], onDelete: Cascade)
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@index([toId])
  @@index([projectId])
}
