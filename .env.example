# Database
DATABASE_URL=postgresql://sitebuilder:password@localhost:5432/sitebuilder

# Telegram auth
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_BOT_USERNAME=your_bot_username

# Session encryption (min 32 chars)
SESSION_SECRET=change-this-to-a-random-32-char-string!!

# OpenAI API key for Whisper (transcription) and Codex/GPT (generation)
OPENAI_API_KEY=sk-...

# Model for site generation (gpt-5.5 recommended, gpt-4.1 as fallback)
OPENAI_MODEL=gpt-5.5

# VDS hosting for one-click publish
VDS_HOST=213.155.10.117
VDS_PORT=22
VDS_USER=root
VDS_PASSWORD=your-password-here
# VDS_PRIVATE_KEY=paste-private-key-here (alternative to password)
VDS_DOMAIN=creatly.ru
VDS_SITES_ROOT=/var/www/creatly

# Access control (comma-separated emails, empty = open access)
ALLOWED_EMAILS=
